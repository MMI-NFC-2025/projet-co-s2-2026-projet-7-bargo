---
// index.astro — Page d'accueil BARGO
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getCollection } from '../js/backend.js';
import PbImage from '../components/PbImage.astro';
import Faq from '../components/Faq.astro';
import Partenaires from '../components/Partenaires.astro';

import arrowRight     from '../assets/icon/arrow-right.svg';
import carouselGauche from '../assets/icon/carousel_gauche.svg';
import carouselDroit  from '../assets/icon/carousel_droit.svg';
import heroBg         from '../assets/img/hero_acceuil.avif';
import jeux1          from '../assets/img/jeux-img-1.avif';
import jeux2          from '../assets/img/jeux-img-2.avif';
import jeux3          from '../assets/img/jeux-img-3.avif';
import jeux4          from '../assets/img/jeux-img-4.avif';
import jeux5          from '../assets/img/jeux-img-5.avif';
import membre1        from '../assets/img/melvyn_philippon.avif';
import membre2        from '../assets/img/pierre_mouilleseaux_lhuillier.avif';
import membre3        from '../assets/img/alex_ringenbach.avif';

const bars = await getCollection('bar', { sort: 'created' });

const faqItems = [
  {
    question: "Qu'est-ce qu'un barathon ?",
    answer: "Un barathon est une tournée organisée de bars entre amis, structurée avec un itinéraire, des défis et un esprit d'équipe. BARGO vous permet de tout organiser simplement."
  },
  {
    question: "Comment créer un barathon ?",
    answer: "Créez votre compte, formez votre groupe, sélectionnez les bars de votre itinéraire et lancez la session. C'est tout !"
  },
  {
    question: "Faut-il payer pour utiliser BARGO ?",
    answer: "Non, BARGO est gratuit pour les utilisateurs. Certaines fonctionnalités premium peuvent être disponibles à l'avenir."
  },
  {
    question: "Comment inviter mes amis ?",
    answer: "Depuis votre espace, vous pouvez inviter vos amis par lien ou par email directement depuis l'interface."
  },
  {
    question: "Peut-on modifier l'itinéraire en cours de soirée ?",
    answer: "Oui, l'organisateur peut ajuster l'itinéraire en temps réel selon les envies du groupe."
  },
  {
    question: "Comment fonctionne le système de jeux ?",
    answer: "Des défis sont proposés automatiquement à chaque étape du barathon. Les joueurs peuvent les accepter ou les passer selon les règles choisies en début de session."
  },
  {
    question: "Mes données sont-elles protégées ?",
    answer: "Oui, vos données sont hébergées de manière sécurisée et ne sont jamais revendues. Consultez nos mentions légales pour plus d'informations."
  }
];
---

<Layout>

  <!-- ==================== HERO ==================== -->
  <section class="relative w-full h-[700px] overflow-hidden">
    <Image src={heroBg} alt="" class="absolute inset-0 w-full h-full object-cover pointer-events-none" />
    <!-- Titre principal — unique h1 de la page -->
    <h1 class="absolute text-white left-[80px] top-[267px] uppercase m-0">
      <span class="block whitespace-nowrap">"Le barathon</span>
      <span class="block whitespace-nowrap mt-[49px]">Autrement"</span>
    </h1>
    <!-- Description bas droite -->
    <p class="absolute text-[#dfdfdf] right-[80px] top-[624px] w-[457px] text-right m-0">
      Une soirée. Un groupe. Un parcours.
    </p>
  </section>

  <!-- ==================== A PROPOS ==================== -->
  <section class="bg-[#f7f1ed] w-full" id="apropos">
    <div class="max-w-[1440px] mx-auto px-20 pt-[94px] pb-[65px]">

      <!-- Ligne intro : h3 col 1-3, description col 5-12 -->
      <div class="flex items-start">
        <h3 class="text-[#1e1e1e] m-0 w-[328px] shrink-0 mt-[61px]">
          Comment ça fonctionne ? C'est très simple.
        </h3>
        <p class="text-[#646262] m-0 w-[662px] ml-[219px]">
          BARGO est une plateforme web dédiée à l'organisation de barathons entre amis. Créez un groupe, sélectionnez vos établissements, attribuez un conducteur responsable et rythmez la soirée avec des défis intégrés.
        </p>
      </div>

      <!-- Steps : 3 colonnes, chaque step = numéro gauche + texte droite -->
      <div class="grid grid-cols-3 mt-[151px]">

        <!-- Step 1 -->
        <div class="flex">
          <span class="font-['Manrope'] font-bold text-[90px] leading-none tracking-[5.4px] text-[#72c073] w-[109px] shrink-0">1</span>
          <div class="flex flex-col pt-[15px]">
            <p class="text-[#1e1e1e] leading-[1.4] m-0">Créez votre profil</p>
            <p class="text-[#646262] text-[14px] leading-[1.1] mt-[24px] w-[296px] m-0">Inscrivez-vous en quelques secondes pour accéder à toutes les fonctionnalités. Personnalisez votre profil et préparez votre prochaine soirée entre amis.</p>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="flex">
          <span class="font-['Manrope'] font-bold text-[90px] leading-none tracking-[5.4px] text-[#347645] w-[109px] shrink-0">2</span>
          <div class="flex flex-col pt-[15px]">
            <p class="text-[#1e1e1e] leading-[1.4] m-0">Invitez vos amis</p>
            <p class="text-[#646262] text-[14px] leading-[1.1] mt-[24px] w-[296px] m-0">Ajoutez vos proches à votre groupe et formez votre équipe. Plus vous êtes nombreux, plus l'expérience devient conviviale et dynamique.</p>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="flex">
          <span class="font-['Manrope'] font-bold text-[90px] leading-none tracking-[5.4px] text-[#094736] w-[109px] shrink-0">3</span>
          <div class="flex flex-col pt-[15px]">
            <p class="text-[#1e1e1e] leading-[1.4] m-0">Organisez votre tournée</p>
            <p class="text-[#646262] text-[14px] leading-[1.1] mt-[24px] w-[296px] m-0">Sélectionnez les bars, définissez l'itinéraire et lancez votre session. Suivez la progression de la soirée et profitez d'un parcours structuré et ludique.</p>
          </div>
        </div>

      </div>

      <!-- H2 en bas, après les steps -->
      <h2 class="text-[#1e1e1e] mt-[196px] m-0">Prêts à démarrer votre parcours ?</h2>

    </div>
  </section>

  <!-- ==================== BAR ==================== -->
  <section class="relative w-full h-[670px] overflow-hidden" id="bars">

    <!-- Track : tous les slides côte à côte, déplacé par translateX -->
    <div id="bar-track" class="flex h-full" style={`width: ${bars.length * 100}%`}>
      {bars.map((bar) => (
        <div class="flex h-full flex-none" style={`width: ${100 / bars.length}%`}>
          <!-- Image -->
          <div class="w-[845px] shrink-0 overflow-hidden">
            <PbImage record={bar} recordImage={bar.img?.[0]} width={845} height={670} />
          </div>
          <!-- Infos -->
          <div class="bg-[#1e1e1e] flex-1 flex flex-col pt-[76px] pl-[109px] pr-[80px]">
            <h2 class="text-white m-0 mb-[35px]">{bar.nom}</h2>
            <p class="text-[#f7f1ed] text-[14px] leading-[1.1] m-0 mb-[52px]">{bar.adresse}</p>
            <p class="text-white w-[297px] m-0 mb-[103px]">{bar.description}</p>
            <a href={`/bar/${bar.id}`} class="inline-flex items-center gap-4 px-12 py-2 border-2 border-white text-white leading-[1.4] w-fit hover:bg-white hover:text-[#1e1e1e] transition-colors">
              Choisir mes bars
              <img src={arrowRight.src} alt="" width="35" height="35" />
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Flèches navigation -->
    <div class="absolute bottom-[97px] right-[80px] flex gap-[17px] z-10">
      <button id="bar-prev" class="w-[43px] h-[43px]" aria-label="Bar précédent">
        <img src={carouselGauche.src} alt="" width="43" height="43" />
      </button>
      <button id="bar-next" class="w-[43px] h-[43px]" aria-label="Bar suivant">
        <img src={carouselDroit.src} alt="" width="43" height="43" />
      </button>
    </div>

  </section>

  <!-- ==================== JEUX ==================== -->
  <section class="bg-[#f7f1ed] pt-20 pb-0 relative w-full" id="jeux">
    <div class="max-w-[1440px] mx-auto px-20">

      <!-- 3 colonnes : texte+jeux4 / jeux1+jeux5 / jeux2+jeux3 -->
      <div class="flex gap-8 items-start">

        <!-- Col 1 : texte en haut, jeux4 en bas -->
        <div class="w-[328px] shrink-0 flex flex-col mt-[43px] pt-[35px] h-[889px]">
          <h3 class="text-[#1e1e1e] mb-[106px] m-0">Des jeux pour animer la soirée</h3>
          <p class="text-[#646262] m-0">Parmi eux, des défis comme toucher son nez, tenir en équilibre quelques secondes, faire la planche sur une chaise ou répéter une phrase sans erreur, et bien d'autres jeux à relever en équipe.</p>
          <div class="w-full h-[297px] rounded-[5px] overflow-hidden mt-auto">
            <Image src={jeux4} alt="Soirée entre amis" class="w-full h-full object-cover block" />
          </div>
        </div>

        <!-- Col 2 : jeux1 (grande) + jeux5 (grande) -->
        <div class="flex flex-col gap-6 shrink-0 mt-[43px]">
          <div class="w-[515px] h-[444px] rounded-[5px] overflow-hidden">
            <Image src={jeux1} alt="Jeux en soirée" class="w-full h-full object-cover block" />
          </div>
          <div class="w-[515px] h-[421px] rounded-[5px] overflow-hidden">
            <Image src={jeux5} alt="Jeux de soirée" class="w-full h-full object-cover block" />
          </div>
        </div>

        <!-- Col 3 : jeux2 + jeux3 empilés -->
        <div class="flex flex-col gap-6 shrink-0 mt-[43px]">
          <div class="w-[296px] h-[325px] rounded-[5px] overflow-hidden">
            <Image src={jeux2} alt="Ambiance soirée" class="w-full h-full object-cover block" />
          </div>
          <div class="w-[296px] h-[220px] rounded-[5px] overflow-hidden">
            <Image src={jeux3} alt="Fête jeux" class="w-full h-full object-cover block" />
          </div>
        </div>

      </div>

    </div>

  </section>

  <!-- ==================== VALEURS ==================== -->
  <section class="bg-[#f7f1ed] w-full">
    <div class="max-w-[1440px] mx-auto px-20 pt-20 pb-[79px]">
      <h2 class="text-[#1e1e1e] m-0">Au rendez-vous</h2>
    </div>
    <div class="grid w-full" style="grid-template-columns: repeat(3, 1fr);">
      <div class="bg-[#72c073] h-[455px] px-20 pt-[90px] pb-16 flex flex-col gap-[61px]">
        <h3 class="text-white m-0">Convivialité</h3>
        <p class="font-medium text-[16px] leading-[1.4] text-[#dfdfdf] m-0">Nous plaçons l'expérience collective au cœur de chaque barathon. BARGO favorise les moments partagés, l'esprit d'équipe et la bonne ambiance afin que chaque sortie reste un souvenir positif entre amis.</p>
      </div>
      <div class="bg-[#347645] h-[455px] px-20 pt-[90px] pb-16 flex flex-col gap-[61px]">
        <h3 class="text-white m-0">Sécurité</h3>
        <p class="font-medium text-[16px] leading-[1.4] text-[#dfdfdf] m-0">La sécurité fait partie intégrante de l'organisation. Attribution d'un conducteur pour la soirée, informations utiles et repères clairs permettent de profiter pleinement tout en gardant le contrôle.</p>
      </div>
      <div class="bg-[#094736] h-[455px] px-20 pt-[90px] pb-16 flex flex-col gap-[61px]">
        <h3 class="text-white m-0">Responsabilité</h3>
        <p class="font-medium text-[16px] leading-[1.4] text-[#dfdfdf] m-0">Un barathon réussi est un barathon maîtrisé. BARGO encourage un comportement responsable et respectueux, pour soi, pour les autres et pour les établissements visités.</p>
      </div>
    </div>
  </section>

  <!-- ==================== EQUIPE ==================== -->
  <section class="bg-[#f7f1ed] py-20 w-full" id="equipe">
    <div class="max-w-[1440px] mx-auto px-20">

      <!-- Header équipe : h2 gauche, description à 765px du bord container -->
      <div class="flex items-start mb-[134px]">
        <div class="w-[765px] shrink-0">
          <h2 class="text-[#1e1e1e] m-0">Notre équipe</h2>
        </div>
        <p class="font-medium text-[16px] leading-[1.4] text-[#646262] m-0 pt-[13px] w-[382px]">Derrière BARGO, une équipe passionnée par l'organisation d'expériences collectives. Nous avons imaginé une plateforme simple, structurée et conviviale pour faciliter vos sorties entre amis.</p>
      </div>

      <!-- Cards membres -->
      <div class="grid gap-7 mb-14" style="grid-template-columns: repeat(3, 1fr);">

        <div class="flex flex-col">
          <div class="w-full h-[495px] rounded-[10px] overflow-hidden mb-[54px]">
            <Image src={membre1} alt="Melvyn Philippon" class="w-full h-full object-cover block" />
          </div>
          <h3 class="text-[#72c073] m-0 mb-[16px]">Melvyn Philippon</h3>
          <p class="font-medium text-[16px] leading-[1.4] text-[#1e1e1e] m-0 mb-[43px]">Designer</p>
          <p class="font-medium text-[14px] leading-[1.1] text-[#646262] m-0">Conçoit l'identité visuelle et l'expérience utilisateur. Il veille à la cohérence graphique et à la simplicité d'utilisation de la plateforme.</p>
        </div>

        <div class="flex flex-col">
          <div class="w-full h-[495px] rounded-[10px] overflow-hidden mb-[54px]">
            <Image src={membre2} alt="Pierre Mouilleseaux-Lhuillier" class="w-full h-full object-cover block" />
          </div>
          <h3 class="text-[#72c073] m-0 mb-[16px]">Pierre Mouilleseaux-Lhuillier</h3>
          <p class="font-medium text-[16px] leading-[1.4] text-[#1e1e1e] m-0 mb-[43px]">Développeur</p>
          <p class="font-medium text-[14px] leading-[1.1] text-[#646262] m-0">Développe et structure la plateforme. Il transforme les idées en fonctionnalités concrètes et assure le bon fonctionnement du site.</p>
        </div>

        <div class="flex flex-col">
          <div class="w-full h-[495px] rounded-[10px] overflow-hidden mb-[54px]">
            <Image src={membre3} alt="Alex Ringenbach" class="w-full h-full object-cover block" />
          </div>
          <h3 class="text-[#72c073] m-0 mb-[16px]">Alex Ringenbach</h3>
          <p class="font-medium text-[16px] leading-[1.4] text-[#1e1e1e] m-0 mb-[43px]">Communication</p>
          <p class="font-medium text-[14px] leading-[1.1] text-[#646262] m-0">Gère l'image et la visibilité du projet. Il s'occupe de la stratégie de communication et du lien avec la communauté.</p>
        </div>

      </div>

      <!-- CTA -->
      <div class="flex justify-end">
        <a href="/Apropos" class="inline-flex items-center gap-4 px-12 py-2 bg-[#1e1e1e] text-white font-medium text-[16px] leading-[1.4] hover:opacity-80 transition-opacity">
          En savoir plus
          <img src={arrowRight.src} alt="" width="35" height="35" />
        </a>
      </div>

    </div>
  </section>

  <!-- ==================== PARTENAIRES ==================== -->
  <Partenaires />

  <Faq items={faqItems} />

</Layout>

<style>
  /* Carousel — transition swipe */
  #bar-track {
    transition: transform 0.5s ease-in-out;
  }

  /* FAQ : rotation du + quand ouvert */
  .faq-item[open] .faq-icon {
    transform: rotate(45deg);
  }
</style>

<script>
  // Carousel bars — swipe par translateX sur le track
  const track = document.getElementById('bar-track');
  if (track) {
    const total = track.children.length;
    let current = 0;

    function showSlide(n) {
      current = n;
      track.style.transform = `translateX(-${n * (100 / total)}%)`;
    }

    document.getElementById('bar-prev').addEventListener('click', () => {
      showSlide((current - 1 + total) % total);
    });

    document.getElementById('bar-next').addEventListener('click', () => {
      showSlide((current + 1) % total);
    });
  }

</script>

<script src="../scripts/drag-scroll.js"></script>
