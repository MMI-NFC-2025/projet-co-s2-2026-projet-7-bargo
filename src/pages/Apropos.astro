---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import Faq from '../components/Faq.astro';
import Partenaires from '../components/Partenaires.astro';

import heroBg       from '../assets/img/hero_aPropos.avif';
import naissanceImg from '../assets/img/jeux-img-4.avif';
import visionImg    from '../assets/img/jeux-img-5.avif';
import membre1      from '../assets/img/melvyn_philippon.avif';
import membre2      from '../assets/img/pierre_mouilleseaux_lhuillier.avif';
import membre3      from '../assets/img/alex_ringenbach.avif';

const faqItems = [
  {
    question: "Qu'est-ce qu'un barathon ?",
    answer: "Un barathon est une tournée organisée de bars entre amis, structurée avec un itinéraire, des défis et un esprit d'équipe. BARGO vous permet de tout organiser simplement."
  },
  {
    question: "Comment créer un barathon ?",
    answer: "Créez un compte, définissez votre itinéraire, ajoutez vos amis et lancez la soirée. L'interface intuitive de BARGO vous guide à chaque étape."
  },
  {
    question: "Faut-il payer pour utiliser BARGO ?",
    answer: "L'utilisation de base de BARGO est gratuite. Des options premium peuvent être disponibles pour des fonctionnalités avancées."
  },
  {
    question: "Comment inviter mes amis ?",
    answer: "Depuis votre barathon créé, partagez le lien d'invitation ou invitez directement vos amis par leur nom d'utilisateur BARGO."
  },
  {
    question: "Peut-on modifier l'itinéraire en cours de soirée ?",
    answer: "Oui, l'organisateur peut modifier l'itinéraire en temps réel depuis l'application, et tous les participants sont notifiés des changements."
  },
  {
    question: "Comment fonctionne le système de jeux ?",
    answer: "BARGO propose une bibliothèque de jeux adaptés aux soirées en bar. Vous pouvez les ajouter à votre barathon et les jouer entre étapes."
  },
  {
    question: "Mes données sont-elles protégées ?",
    answer: "Oui, BARGO respecte le RGPD et applique des mesures de sécurité strictes pour protéger vos données personnelles."
  }
];
---

<Layout>

  <!-- ==================== HERO ==================== -->
  <section class="relative h-[700px] overflow-hidden">
    <Image src={heroBg} alt="" class="absolute inset-0 w-full h-full object-cover pointer-events-none" />
    <div class="absolute inset-0 bg-gradient-to-b from-[rgba(30,30,30,0.7)] to-[#1e1e1e]"></div>
    <h1 class="absolute top-[498px] right-[80px] text-right text-white uppercase m-0 w-[927px]">
      Qui somme-nous
    </h1>
  </section>

  <!-- ==================== LA NAISSANCE DU PROJET ==================== -->
  <!--
    z-[2] + overflow-visible : l'image droite (h=567px) déborde de 151px
    dans la section sombre suivante, mais reste visible grâce au z-index 2.
  -->
  <section class="relative h-[576px] bg-[#f7f1ed] overflow-visible z-[2]">
    <h2 class="absolute top-[187px] left-[80px] text-black m-0 w-[405px]">
      La naissance du projet
    </h2>
    <p class="absolute top-[346px] left-[80px] w-[515px] text-[#646262] m-0">
      BARGO est né d'un constat simple : organiser une tournée de bars entre amis devient vite compliqué.
      Messages dispersés, choix des bars au dernier moment, absence d'itinéraire clair…
      L'idée est alors apparue de créer une plateforme dédiée à l'organisation des barathons,
      afin de structurer l'expérience tout en conservant l'aspect convivial.
    </p>
    <!-- Image droite — déborde 151px dans la section sombre -->
    <div class="absolute top-[160px] left-[calc(50%+16px)] w-[704px] h-[567px] rounded-tl-[10px] rounded-bl-[10px] overflow-hidden">
      <Image src={naissanceImg} alt="La naissance du projet" class="w-full h-full object-cover block pointer-events-none" />
    </div>
  </section>

  <!-- ==================== NOTRE VISION / NOS OBJECTIFS ==================== -->
  <!--
    z-[1] + overflow-visible : l'image gauche (h=644px) déborde de 245px
    dans la section beige équipe suivante.
  -->
  <section class="relative h-[799px] bg-[#1e1e1e] overflow-visible z-[1]">
    <h2 class="absolute top-[101px] left-[80px] text-white m-0">
      Notre vision
    </h2>
    <p class="absolute top-[214px] left-[80px] w-[405px] text-[#dfdfdf] m-0">
      BARGO ne se limite pas à l'organisation d'une soirée. Le projet vise à proposer une expérience
      collective structurée, où convivialité et responsabilité vont de pair.
    </p>
    <!-- Image gauche — déborde 245px dans la section beige suivante -->
    <div class="absolute top-[400px] left-0 w-[704px] h-[644px] rounded-tr-[10px] rounded-br-[10px] overflow-hidden">
      <Image src={visionImg} alt="Notre vision" class="w-full h-full object-cover block pointer-events-none" />
    </div>
    <h2 class="absolute top-[400px] left-[calc(58.33%+5px)] text-white m-0">
      Nos objectifs
    </h2>
    <div class="absolute top-[548px] left-[calc(58.33%+5px)] w-[406px] text-[#dfdfdf]">
      <p class="m-0">Simplifier l'organisation des sorties entre amis</p>
      <p class="m-0">&nbsp;</p>
      <p class="m-0">Encourager une approche responsable</p>
      <p class="m-0">&nbsp;</p>
      <p class="m-0">Valoriser l'expérience collective</p>
      <p class="m-0">&nbsp;</p>
      <p class="m-0">Proposer une interface intuitive et accessible</p>
    </div>
  </section>

  <!-- ==================== COLLABORATION + ÉQUIPE ==================== -->
  <section class="relative h-[2080px] bg-[#f7f1ed]">

    <!-- Une collaboration collective -->
    <h2 class="absolute top-[364px] left-[80px] text-black m-0 w-[515px]">
      Une collaboration collective
    </h2>
    <p class="absolute top-[375px] left-[calc(50%+16px)] w-[624px] text-[#1e1e1e] m-0">
      Ce projet a pu voir le jour grâce à la coordination de notre équipe et au soutien de nos nombreux
      partenaires. Leur collaboration et leur engagement ont contribué à faire de BARGO une plateforme
      cohérente et aboutie.
    </p>

    <!-- Melvyn — photo gauche, texte droite -->
    <div class="absolute top-[668px] left-[80px] w-[296px] h-[296px] rounded-bl-[1000px] rounded-tl-[1000px] rounded-tr-[1000px] overflow-hidden">
      <Image src={membre1} alt="Melvyn Philippon" class="w-full h-full object-cover block pointer-events-none" />
    </div>
    <h2 class="absolute top-[668px] left-[calc(25%+48px)] text-[#72c073] m-0">Notre Designer</h2>
    <h3 class="absolute top-[740px] left-[calc(25%+48px)] text-[#1e1e1e] m-0 w-[296px]">Melvyn Philippon</h3>
    <p class="absolute top-[816px] left-[calc(25%+48px)] w-[515px] text-[#646262] m-0">
      Responsable de l'identité visuelle et de l'expérience utilisateur, il a conçu l'univers graphique
      de BARGO ainsi que l'interface. Son objectif : proposer une navigation claire, moderne et cohérente
      avec les valeurs du projet.
    </p>

    <!-- Pierre — photo décalée vers le centre -->
    <div class="absolute top-[1098px] left-[calc(16.67%+59px)] w-[296px] h-[296px] rounded-br-[1000px] rounded-tl-[1000px] rounded-tr-[1000px] overflow-hidden">
      <Image src={membre2} alt="Pierre Mouilleseaux-Lhuillier" class="w-full h-full object-cover block pointer-events-none" />
    </div>
    <h2 class="absolute top-[1098px] left-[calc(41.67%+27px)] text-[#72c073] m-0">Notre Développeur</h2>
    <h3 class="absolute top-[1170px] left-[calc(41.67%+27px)] text-[#1e1e1e] m-0 w-[405px]">Pierre Mouilleseaux-Lhuillier</h3>
    <p class="absolute top-[1246px] left-[calc(41.67%+27px)] w-[514px] text-[#646262] m-0">
      En charge de la conception technique, il a structuré l'architecture du site et développé les
      fonctionnalités principales. Il veille à la performance, à la fluidité et au bon fonctionnement
      de la plateforme.
    </p>

    <!-- Alex — photo gauche, texte droite -->
    <div class="absolute top-[1528px] left-[80px] w-[296px] h-[296px] rounded-bl-[1000px] rounded-tl-[1000px] rounded-tr-[1000px] overflow-hidden">
      <Image src={membre3} alt="Alex Ringenbach" class="w-full h-full object-cover block pointer-events-none" />
    </div>
    <h2 class="absolute top-[1528px] left-[calc(25%+48px)] text-[#72c073] m-0 w-[515px]">Notre responsable Communication</h2>
    <h3 class="absolute top-[1650px] left-[calc(25%+48px)] text-[#1e1e1e] m-0 w-[296px]">Alex Ringenbach</h3>
    <p class="absolute top-[1726px] left-[calc(25%+48px)] w-[515px] text-[#646262] m-0">
      Il définit la stratégie de communication et l'image du projet. Il s'occupe de la cohérence du
      discours, de la présentation du concept et de la mise en avant des valeurs de BARGO.
    </p>

  </section>

  <!-- ==================== PARTENAIRES ==================== -->
  <Partenaires />

  <!-- ==================== SORTIR ENSEMBLE ==================== -->
  <section class="relative h-[507px] bg-[#f7f1ed]">
    <h2 class="absolute top-[136px] left-[80px] text-black m-0 w-[733px]">
      Sortir ensemble, en toute responsabilité
    </h2>
    <p class="absolute top-[264px] left-[calc(58.33%+5px)] w-[515px] text-[#646262] m-0">
      Un barathon doit rester un moment convivial et maîtrisé. Pensez à organiser votre retour à l'avance,
      à désigner un conducteur pour la soirée et à respecter vos limites. L'abus d'alcool est dangereux
      pour la santé. Consommez avec modération.
    </p>
  </section>

  <!-- ==================== FAQ ==================== -->
  <Faq items={faqItems} />

</Layout>
