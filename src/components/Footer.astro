---
// Footer.astro — pied de page avec fond image, overlay, navigation, réseaux sociaux
import { Image } from 'astro:assets';
import logoLight   from '../assets/icon/logo-light.svg';
import footerBg    from '../assets/img/footer.avif';
import iconFb      from '../assets/icon/facebook.svg';
import iconInsta   from '../assets/icon/insta.svg';
import iconDiscord from '../assets/icon/discord.svg';
---

<footer class="relative w-full h-[684px] overflow-hidden">

  <!-- Image de fond -->
  <Image src={footerBg} alt="" class="absolute inset-0 w-full h-full object-cover pointer-events-none" />

  <!-- Overlay dégradé -->
  <div class="absolute inset-0 footer-overlay"></div>

  <!-- Contenu principal -->
  <div class="relative z-10 max-w-[1440px] mx-auto px-20 pt-20 grid gap-10" style="grid-template-columns: 240px 200px 200px 1fr 200px;">

    <!-- Logo -->
    <div>
      <Image src={logoLight} alt="Bargo" width="173" height="70" class="h-[70px] w-auto block" />
    </div>

    <!-- Navigation -->
    <nav class="flex flex-col gap-2">
      <p class="font-['Manrope'] font-medium text-[25px] leading-[1.4] tracking-[-0.04em] text-[#72c073] mb-2 m-0">NAVIGATION</p>
      <a href="/bars" class="font-medium text-base leading-[1.4] text-[#f7f1ed] hover:opacity-70 transition-opacity">Voir tous les bars</a>
      <a href="/jeux" class="font-medium text-base leading-[1.4] text-[#f7f1ed] hover:opacity-70 transition-opacity">Liste des jeux</a>
      <a href="/boutique" class="font-medium text-base leading-[1.4] text-[#f7f1ed] hover:opacity-70 transition-opacity">Boutique</a>
      <a href="/apropos" class="font-medium text-base leading-[1.4] text-[#f7f1ed] hover:opacity-70 transition-opacity">A propos</a>
    </nav>

    <!-- Informations -->
    <nav class="flex flex-col gap-2">
      <p class="font-['Manrope'] font-medium text-[25px] leading-[1.4] tracking-[-0.04em] text-[#72c073] mb-2 m-0">INFORMATIONS</p>
      <a href="/partenaires" class="font-medium text-base leading-[1.4] text-[#f7f1ed] hover:opacity-70 transition-opacity">Partenaires</a>
      <a href="/contact" class="font-medium text-base leading-[1.4] text-[#f7f1ed] hover:opacity-70 transition-opacity">Contact</a>
    </nav>

    <!-- Prévention -->
    <div>
      <p class="font-['Manrope'] font-medium text-[25px] leading-[1.4] tracking-[-0.04em] text-[#72c073] mb-2 m-0">PRÉVENTION</p>
      <p class="font-medium text-base leading-[1.4] text-[#f7f1ed] m-0">
        Votre sécurité avant tout<br />
        L'abus d'alcool est dangereux pour la santé. BARGO vous accompagne pour des soirées responsables.
      </p>
    </div>

    <!-- Réseaux sociaux -->
    <div>
      <p class="font-['Manrope'] font-medium text-[25px] leading-[1.4] tracking-[-0.04em] text-[#72c073] mb-6 m-0">SUIVEZ-NOUS</p>
      <div class="flex gap-3 items-center">
        <a href="#" class="opacity-90 hover:opacity-100 transition-opacity" aria-label="Facebook">
          <img src={iconFb.src} alt="Facebook" width="48" height="48" />
        </a>
        <a href="#" class="opacity-90 hover:opacity-100 transition-opacity" aria-label="Instagram">
          <img src={iconInsta.src} alt="Instagram" width="48" height="48" />
        </a>
        <a href="#" class="opacity-90 hover:opacity-100 transition-opacity" aria-label="Discord">
          <img src={iconDiscord.src} alt="Discord" width="48" height="48" />
        </a>
      </div>
    </div>

  </div>

  <!-- Ligne séparatrice -->
  <div class="relative z-10 max-w-[1440px] mx-auto px-20 mt-10">
    <div class="border-t border-[#f7f1ed]/30"></div>
  </div>

  <!-- Bas de page -->
  <div class="relative z-10 max-w-[1440px] mx-auto px-20 py-5 flex justify-between items-center">
    <p class="font-medium text-base leading-[1.4] text-[#f7f1ed] m-0">© 2026 BARGO</p>
    <a href="/mentions-legales" class="font-medium text-base leading-[1.4] text-[#f7f1ed] hover:opacity-70 transition-opacity">Mentions légales</a>
  </div>

</footer>

<style>
  .footer-overlay {
    background: linear-gradient(to bottom, rgba(30, 30, 30, 0.7), #1e1e1e);
  }
</style>